DECKS_DIR=./decks
DB_PATH=./markcards.db
PORT=3000

# GitHub deck source (optional — if set, decks are fetched from GitHub instead of DECKS_DIR)
# GITHUB_REPO=owner/repo          # e.g. "alice/flashcards"
# GITHUB_TOKEN=ghp_...            # personal access token (required for private repos; raises rate limit to 5000/hr)
# GITHUB_BRANCH=main              # branch to read from (default: main)
# GITHUB_PATH=                    # subdirectory within the repo, e.g. "decks" (default: repo root)
# SYNC_TTL_MS=60000               # how often to re-fetch from GitHub, in ms (default: 60 seconds)
