{
	email {$ACME_EMAIL}
}

*.{$DOMAIN} {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
		resolvers nina.ns.cloudflare.com randy.ns.cloudflare.com
		propagation_delay 60s
	}

	@markcards host markcards.{$DOMAIN}
	handle @markcards {
		reverse_proxy client:3001
	}

	@markcards-api host markcards-api.{$DOMAIN}
	handle @markcards-api {
		reverse_proxy server:3000
	}

	handle {
		abort
	}
}
